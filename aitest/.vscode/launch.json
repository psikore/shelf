{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Server",
            "type": "debugpy",
            "request": "launch",
            "module": "server",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Client: Probe",
            "type": "debugpy",
            "request": "launch",
            "module": "client",
            "args": ["probe", "--timeout", "10"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Client: Echo",
            "type": "debugpy",
            "request": "launch",
            "module": "client",
            "args": ["echo", "hello world"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
